local function tp(pos, reason)
    character = lp.Character
    if not character or not pos then log("TP","SKIPPED — no char/pos | "..tostring(reason)) return end
    local r = character:FindFirstChild("HumanoidRootPart")
    if not r then log("TP","SKIPPED — no HRP | "..tostring(reason)) return end
    local curPos = r.Position
    log("TP", string.format("%s -> %.1f,%.1f,%.1f | was %.1f,%.1f,%.1f",
        tostring(reason), pos.X, pos.Y, pos.Z, curPos.X, curPos.Y, curPos.Z))
    r.CFrame = CFrame.new(pos)
    task.wait(0.05)
end

