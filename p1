    clearAnchor()
    log("RESPAWN", string.format(
        "CharacterAdded | gi=%s(done=%s,mode=%s) hatch=%s season=%s rift=%s obsrift=%s doodle=%s j4rift=%s genie=%s | egg=%s",
        tostring(State.giRunning), tostring(State.giQuestsDone), tostring(State.giMode),
        tostring(State.hatchRunning), tostring(State.seasonRunning), tostring(State.riftRunning),
        tostring(State.obsidianRiftRunning), tostring(State.doodleRiftRunning),
        tostring(State.july4thRiftRunning), tostring(State.genieRunning),
        tostring(State.selectedEggKey)
    ))
    if riftActive() and State.riftHatchPos then
        tp(State.riftHatchPos,"respawn_rift") return
    end
    if State.obsidianRiftRunning and State.obsidianRiftHatchPos then
        tp(State.obsidianRiftHatchPos,"respawn_obsrift") return
    end
    if State.doodleRiftRunning and State.doodleRiftHatchPos then
        tp(State.doodleRiftHatchPos,"respawn_doodle") return
    end
    if State.july4thRiftRunning and State.july4thRiftHatchPos then
        tp(State.july4thRiftHatchPos,"respawn_j4rift") return
    end
    if State.giRunning and not State.giQuestsDone then
        if State.giMode=="bub" then
            tp(EGG_POSITIONS.BubbleZone,"respawn_gi_bub")
        elseif State.giMode=="leg" then
            tp(EGG_POSITIONS.SpikeyEgg,"respawn_gi_leg")
        elseif State.giMode=="reg" then
            tp(EGG_POSITIONS[State.selectedEggKey],"respawn_gi_reg")
        end
    elseif State.hatchRunning and not seasonBlocking() and not genieBlocking() then
        tp(EGG_POSITIONS[State.selectedEggKey],"respawn_hatch")
    end
end)

