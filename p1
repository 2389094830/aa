-- RIFT WORKSPACE HELPERS
-- ══════════════════════════════════════════
local function eggNameToSlug(name)
    return name:lower():gsub("%s+", "-")
end
local function getRiftsFolder()
    local rendered = workspace:FindFirstChild("Rendered")
    if not rendered then return nil end
    return rendered:FindFirstChild("Rifts")
end
local function getModelPosition(model)
    if not model then return nil end
    if model.PrimaryPart then return model.PrimaryPart.Position end
    for _, child in ipairs(model:GetDescendants()) do
        if child:IsA("BasePart") then return child.Position end
    end
    return nil
end
local function getRiftPlatformPositions(slug)
    local riftsFolder = getRiftsFolder()
    if not riftsFolder then log("RIFT","Rendered.Rifts not found") return {} end
    local positions = {}
    for _, riftModel in ipairs(riftsFolder:GetChildren()) do
        if riftModel.Name == slug then
            local platform = riftModel:FindFirstChild("EggPlatformSpawn", true)
            local pos = nil
            if platform then
                if platform:IsA("BasePart") then pos = platform.Position
                elseif platform:IsA("Model") then pos = getModelPosition(platform) end
                if not pos then
                    for _, desc in ipairs(platform:GetDescendants()) do
                        if desc:IsA("BasePart") then pos = desc.Position break end
                    end
                end
            end
            if not pos then
                for _, desc in ipairs(riftModel:GetDescendants()) do
                    if desc:IsA("BasePart") then pos = desc.Position break end
                end
            end
            if pos then
                table.insert(positions, pos)
            end
        end
    end
    return positions
end
local function pickClosestPlatform(positions, targetY)
    if #positions == 0 then return nil end
    if #positions == 1 then return positions[1] end
    local best, bestDist = positions[1], math.abs(positions[1].Y - targetY)
    for i = 2, #positions do
        local d = math.abs(positions[i].Y - targetY)
        if d < bestDist then bestDist=d best=positions[i] end
    end
    return best
end
local function findRiftHatchPos(eggName, spawnHeight)
    local slug = eggNameToSlug(eggName)
    local deadline = tick() + 8
    local positions = {}
    repeat
        positions = getRiftPlatformPositions(slug)
        if #positions == 0 then task.wait(0.25) end
    until #positions > 0 or tick() >= deadline
    if #positions == 0 then log("RIFT","Timed out waiting for rift model") return nil end
    return pickClosestPlatform(positions, spawnHeight)
end

