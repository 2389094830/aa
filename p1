-- ══════════════════════════════════════════
-- ENCHANT LOOP
-- ══════════════════════════════════════════
local function runEnchantLoop()
    local function getSecrets()
        local data = LocalData:Get() if not data then return {} end
        local team = data.Teams and data.Teams[data.TeamEquipped]
        if not team then return {} end
        local pm={} for _,p in ipairs(data.Pets) do pm[p.Id]=p end
        local seen,out={},{}
        for _,id in ipairs(team.Pets) do
            if not seen[id] then seen[id]=true
                local pet=pm[id]
                if pet then local pd=PetData[pet.Name] if pd and pd.Rarity=="Secret" then table.insert(out,pet) end end
            end
        end
        return out
    end
    local function hasShadow() local d=LocalData:Get() return d and d.Powerups and (d.Powerups["Shadow Crystal"] or 0)>0 end
    local function hasTargets(pet)
        if not pet.Enchants or #pet.Enchants==0 then return false end
        local own={} for _,e in ipairs(pet.Enchants) do own[e.Id]=true end
        for _,t in ipairs(State.enchantTargets) do if not own[t] then return false end end
        return true
    end
    local function getBad(pet)
        if not pet.Enchants then return nil end
        for i,e in ipairs(pet.Enchants) do
            local isT=false for _,t in ipairs(State.enchantTargets) do if e.Id==t then isT=true break end end
            if not isT then return i end
        end
    end
    local function getGood(pet,bad)
        if not pet.Enchants then return nil end
        for i,e in ipairs(pet.Enchants) do
            if i~=bad then for _,t in ipairs(State.enchantTargets) do if e.Id==t then return i end end end
        end
    end
    while State.enchanting do
        local secs = getSecrets()
        if #secs==0 then setAction("Enchant: no secrets") task.wait(2)
        else
            local tgt,bad,lock=nil,nil,nil
            for _,p in ipairs(secs) do
                if not hasTargets(p) then bad=getBad(p) tgt=p lock=bad and getGood(p,bad) or nil break end
            end
            if not tgt then
                setAction("Enchant: all done")
                for i=30,1,-1 do if not State.enchanting then break end task.wait(1) end
            elseif hasShadow() then
                setAction("Enchant: Shadow Crystal > "..tgt.Name)
                Remote:FireServer("UseShadowCrystal",tgt.Id,lock) task.wait(1.5)
            else
                local cur = State.enchantCurrency or "Gems"
                setAction("Enchant: rerolling "..tgt.Name.." ["..cur.."]")
                local r=Remote:InvokeServer("RerollEnchants",tgt.Id,cur,lock)
                if not r then setAction("Enchant: insufficient "..cur) task.wait(2) else task.wait(0.8) end
            end
        end
        task.wait(0.05)
    end
    setAction("Idle")
end

