                                    local v = pet.Mythic and "Mythic " or pet.Shiny and "Shiny " or pet.XL and "XL " or ""
                                    sendWebhookEmbed(pet.Name, v, false)
                                end)
                            end
                        end
                    end
                end
            end
            if State.skipAnim then return end
            return orig(self, data)
        end))
        log("INIT","anim hook ok")
    end
end

-- ══════════════════════════════════════════
-- QUEST HELPERS
-- ══════════════════════════════════════════
local function getQuestEntry(data, ctype, idx)
    local id = ("%s-challenge-%d"):format(string.lower(ctype), idx)
    if QuestUtil.FindById then return QuestUtil:FindById(data, id) end
    if data and data.Quests then
        for _, q in pairs(data.Quests) do
            if type(q)=="table" and q.Id==id then return q end
        end
    end
end

-- FIXED: direct string comparison, no table lookup needed
local function isBlacklistedTask(t1)
    if not t1 or t1.Type ~= "Collect" then return false end
    local cur = t1.Item and t1.Item.Currency
    return cur == "Pearls" or cur == "Tickets"
end

-- FIXED: direct check before anything else
local function resolveQuestAction(t1)
    if not t1 then return "_hatch_total", nil end
    local typ = t1.Type or ""
    if typ == "Collect" then
        local cur = t1.Item and t1.Item.Currency
        if cur == "Pearls" or cur == "Tickets" then return "_skip", nil end
        return (cur == "Gems") and "_gem" or "_coin", cur
    end
    if typ == "Bubbles" then return "_bubble", nil end
    if typ == "Hatch" then
        if t1.Egg and t1.Egg ~= ""       then return "_hatch_specific", resolveEggKey(t1.Egg) end
        if t1.Rarity and t1.Rarity ~= "" then return "_hatch_rarity",   t1.Rarity end
        return "_hatch_total", nil
    end
    return "_hatch_total", nil
end

local function slotHasBlacklistedTask(tasks)
    if not tasks then return false end
    for _, t1 in ipairs(tasks) do
        if isBlacklistedTask(t1) then return true end
    end
    return false
end

-- ══════════════════════════════════════════
-- SEASON QUEST DATA
-- ══════════════════════════════════════════
local function fillQuestData(ctype)
    local data = LocalData:Get()
    if not data then return true, {} end
    local allDone, det = true, {}
    for i = 1,3 do
        local quest = getQuestEntry(data, ctype, i)
        if quest then
            local prog = (quest.Progress and quest.Progress[1]) or 0
            local t1   = quest.Tasks and quest.Tasks[1]
            local req  = getTaskReq(t1)
            local blacklisted = isBlacklistedTask(t1)
            local done = blacklisted or quest.Claimed or (req>0 and prog>=req)
            if not done then allDone = false end
            if blacklisted then
                log("QUEST","Blacklisted: "..tostring(t1 and t1.Item and t1.Item.Currency).." (idx="..i.." "..ctype..")")
            end
            local tstr = t1 and ((QuestUtil.FormatTask and QuestUtil:FormatTask(t1)) or (t1.Type or "?").." x"..req) or "Quest #"..i
            table.insert(det, {task=t1, completed=done, prog=prog, req=req, name=tstr, ctype=ctype, blacklisted=blacklisted})
        end
    end
    return allDone, det
end
local function updateQuests()
    local hd, hdet = fillQuestData("Hourly")
    local dd, ddet = fillQuestData("Daily")
    local changed = (hd ~= State.hourlyDone) or (dd ~= State.dailyDone)
    State.hourlyDone=hd  State.dailyDone=dd
    State.hourlyDet=hdet State.dailyDet=ddet
    if changed then
        log("STATE", string.format("Quest update: hourlyDone=%s dailyDone=%s", tostring(hd), tostring(dd)))
    end
end

local function getCurrencyProgress(ctype, currency)
    local data = LocalData:Get() if not data then return 0,0 end
    for i=1,3 do
        local qe = getQuestEntry(data,ctype,i) if qe then
            local t = qe.Tasks and qe.Tasks[1]
            if t and t.Type=="Collect" then
                local qc = t.Item and t.Item.Currency
                if not currency or qc==currency then
                    return (qe.Progress and qe.Progress[1]) or 0, getTaskReq(t)
                end
            end
        end
    end
    return 0,0
end
local function getBubbleProgress(ctype)
    local data = LocalData:Get() if not data then return 0,0 end
    for i=1,3 do
        local qe = getQuestEntry(data,ctype,i) if qe then
            local t = qe.Tasks and qe.Tasks[1]
            if t and t.Type=="Bubbles" then return (qe.Progress and qe.Progress[1]) or 0, getTaskReq(t) end
        end
    end
    return 0,0
end
local function getHatchProgress(ctype, eggKey, rarity)
    local data = LocalData:Get() if not data then return 0,0 end
    for i=1,3 do
        local qe = getQuestEntry(data,ctype,i) if qe then
            local t = qe.Tasks and qe.Tasks[1]
            if t and t.Type=="Hatch" then
                local m = false
                if eggKey     then m = resolveEggKey(t.Egg or "")==eggKey
                elseif rarity then m = t.Rarity==rarity
                else m = (not t.Egg or t.Egg=="") and (not t.Rarity or t.Rarity=="") end
                if m then return (qe.Progress and qe.Progress[1]) or 0, getTaskReq(t) end
            end
        end
    end
    return 0,0
end

-- ══════════════════════════════════════════
-- SHARED SUB-TASK EXECUTORS
-- ══════════════════════════════════════════
local function doCurrencyCollect(currency, doneFn, sc, sf)
    local picks = (currency == "Gems") and GEM_PICKUP_POSITIONS or COIN_PICKUP_POSITIONS
    while sc() do
        if doneFn() then clearAnchor() return true end
        for idx, pos in ipairs(picks) do
            if not sc() then clearAnchor() return false end
            if doneFn() then clearAnchor() return true end
            sf("Pickup "..idx.."/"..#picks) setAction("Collect pickup "..idx)
            ensureAt("pick"..idx, pos, sc) task.wait(0.5)
        end
        if doneFn() then clearAnchor() return true end
        if currency ~= "Gems" then
            local rbp = EGG_POSITIONS.RainbowEgg
            if rbp then
                sf("Draining coins") setAction("Collect drain")
                local t0 = tick()
                while sc() and tick()-t0<5 do
                    if doneFn() then clearAnchor() return true end
                    ensureAt("rainbow", rbp, sc) spamER() task.wait(0.05)
                end
            else task.wait(2) end
        end
    end
    clearAnchor() return false
end

local function doBubble(doneFn, sc, sf)
    local bp = EGG_POSITIONS.BubbleZone
    if not bp then sf("Save Bubble Zone!") task.wait(2) return false end
    if doneFn() then clearAnchor() return true end
    sf("Bubbling...") setAction("Bubble")
    while sc() do
        if doneFn() then clearAnchor() return true end
        ensureAt("bubble", bp, sc)
        pcall(function() Remote:FireServer("BlowBubble") end) task.wait(0.1)
    end
    clearAnchor() return false
end

local function doHatchAtKey(useKey, doneFn, sc, sf, label)
    local pos = EGG_POSITIONS[useKey]
    if not pos then sf("No pos: "..tostring(useKey)) task.wait(2) return false end
    if doneFn() then clearAnchor() return true end
    sf(label or EGG_KEY_TO_NAME[useKey] or useKey) setAction("Hatch "..useKey)
    while sc() do
        if doneFn() then clearAnchor() return true end
        ensureAt("hatch_"..useKey, pos, sc) spamER() task.wait(0.05)
    end
    clearAnchor() return false
end

local function resolveHatchKey(eggKeyFromTask, rarity)
    if rarity == "Unique"                               then return "SpikeyEgg"         end
    if rarity                                           then return "InfinityEgg"       end
    if eggKeyFromTask and EGG_POSITIONS[eggKeyFromTask] then return eggKeyFromTask      end
    if EGG_POSITIONS[State.selectedEggKey]              then return State.selectedEggKey end
    return "InfinityEgg"
end

-- ══════════════════════════════════════════
-- SEASON SUB-TASKS
-- ══════════════════════════════════════════
local function doCurrencyQuest(q, sc, sf)
    local currency = q.task and q.task.Item and q.task.Item.Currency
    local ctype    = q.ctype
    local function done() local p,r=getCurrencyProgress(ctype,currency) return r>0 and p>=r end
    return doCurrencyCollect(currency, done, sc, sf)
end
local function doBubbleQuest(q, sc, sf)
    local ctype = q.ctype
    local function done() local p,r=getBubbleProgress(ctype) return r>0 and p>=r end
    return doBubble(done, sc, sf)
end
local function doHatchQuest(q, eggKey, rarity, sc, sf)
    local ctype  = q.ctype
    local useKey = resolveHatchKey(eggKey, rarity)
    log("STATE", string.format("doHatchQuest: eggKey=%s rarity=%s -> useKey=%s", tostring(eggKey), tostring(rarity), tostring(useKey)))
    local function done() local p,r=getHatchProgress(ctype,eggKey,rarity) return r>0 and p>=r end
    return doHatchAtKey(useKey, done, sc, sf)
end

-- ══════════════════════════════════════════
-- SEASON LOOP — DO NOT MODIFY TP/GUARD LOGIC
-- ══════════════════════════════════════════
local function runSeasonLoop()
    log("SEASON","started")
    local lastCheck = 0
    while State.seasonRunning do
        if giBlocking() then setAction("Season: waiting G.Inc") task.wait(0.5) continue end
        if tick()-lastCheck>=2 then lastCheck=tick() updateQuests() end
        if State.hourlyDone and State.dailyDone then setAction("Season done") task.wait(10) continue end
        local allQ = {}
        for _,q in ipairs(State.hourlyDet) do table.insert(allQ,q) end
        for _,q in ipairs(State.dailyDet)  do table.insert(allQ,q) end
        local found = false
        for _,q in ipairs(allQ) do
            if not q.completed then
                found = true
                local act, extra = resolveQuestAction(q.task)
                log("SEASON","Dispatching: act="..tostring(act).." extra="..tostring(extra))
                local function sc() return State.seasonRunning and not giBlocking() end
                local function sf(t) setAction("Season: "..t) end
                if act == "_skip" then
                    log("SEASON","_skip — forcing completed")
                    q.completed = true
                elseif act=="_coin" or act=="_gem" then doCurrencyQuest(q,sc,sf)
                elseif act=="_bubble" then doBubbleQuest(q,sc,sf)
                elseif act=="_hatch_specific" then doHatchQuest(q,extra,nil,sc,sf)
                elseif act=="_hatch_rarity"   then doHatchQuest(q,nil,extra,sc,sf)
                else doHatchQuest(q,nil,nil,sc,sf) end
                updateQuests() break
            end
        end
        if not found then task.wait(1) end
    end
    clearAnchor() setAction("Idle") log("SEASON","stopped")
end

