local function safeReq(...)
    local obj = ReplicatedStorage
    for _, part in ipairs({...}) do
        local ok, res = pcall(function() return obj:WaitForChild(part, 10) end)
        if not ok or not res then return nil end
        obj = res
    end
    local ok2, res2 = pcall(require, obj)
    return ok2 and res2 or nil
end

