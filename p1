local function getPassiveRiftInfo(slugList)
    local riftsFolder = getRiftsFolder()
    if not riftsFolder then return nil end
    for _, slug in ipairs(slugList) do
        for _, child in ipairs(riftsFolder:GetChildren()) do
            if child.Name == slug then
                local pos = nil
                local platform = child:FindFirstChild("EggPlatformSpawn", true)
                if platform then
                    if platform:IsA("BasePart") then pos = platform.Position
                    elseif platform:IsA("Model") then pos = getModelPosition(platform) end
                    if not pos then
                        for _, desc in ipairs(platform:GetDescendants()) do
                            if desc:IsA("BasePart") then pos = desc.Position break end
                        end
                    end
                end
                if not pos then
                    for _, desc in ipairs(child:GetDescendants()) do
                        if desc:IsA("BasePart") then pos = desc.Position break end
                    end
                end
                if pos then
                    return {slug=slug, pos=pos, model=child}
                end
            end
        end
    end
    return nil
end
local function passiveRiftStillExists(slug)
    local riftsFolder = getRiftsFolder()
    if not riftsFolder then return false end
    for _, child in ipairs(riftsFolder:GetChildren()) do
        if child.Name == slug then return true end
    end
    return false
end

