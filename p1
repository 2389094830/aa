-- ══════════════════════════════════════════
-- REBIRTH MACHINE (new in v17)
-- Finds 5 non-locked, non-XL, non-team Secret pets matching petName,
-- then fires UseRebirthMachine with their IDs.
-- ══════════════════════════════════════════
local function getRebirthPets(petName)
    local data = LocalData:Get()
    if not data or not data.Pets then return nil end
    -- Build team pet set so we skip equipped pets
    local teamPetIds = {}
    if data.Teams and data.TeamEquipped then
        local team = data.Teams[data.TeamEquipped]
        if team and team.Pets then
            for _, id in ipairs(team.Pets) do teamPetIds[id] = true end
        end
    end
    local found = {}
    for _, pet in ipairs(data.Pets) do
        if pet.Name == petName and not pet.Locked and not pet.XL and not teamPetIds[pet.Id] then
            local pd = PetData[pet.Name]
            if pd and pd.Rarity == "Secret" then
                table.insert(found, pet)
                if #found >= 5 then break end
            end
        end
    end
    return #found >= 5 and found or nil
end

local function runRebirthMachineLoop()
    log("REBIRTH","started | petName="..tostring(State.rebirthConfig.petName))
    while State.rebirthRunning do
        if giBlocking()     then setAction("Rebirth: waiting G.Inc")  task.wait(0.5) continue end
        if seasonBlocking() then setAction("Rebirth: waiting Season") task.wait(0.5) continue end

        local petName = State.rebirthConfig.petName
        local pets    = getRebirthPets(petName)

        if not pets then
            State.rebirthLastCount = 0
            local data = LocalData:Get()
            if data and data.Pets then
                for _, p in ipairs(data.Pets) do
                    if p.Name == petName then
                        State.rebirthLastCount += 1
                    end
                end
            end
            setAction("Rebirth: need 5x "..petName.." ("..State.rebirthLastCount.." found)")
            task.wait(5)
            continue
        end

        -- Build ID array
        local ids = {}
        for _, p in ipairs(pets) do table.insert(ids, p.Id) end

        setAction("Rebirth: converting 5x "..petName.."...")
        log("REBIRTH","Firing UseRebirthMachine with "..#ids.." pets")

        local ok, result = pcall(function()
            return Remote:InvokeServer("UseRebirthMachine", ids)
        end)

        if ok and result then
            local variantName = "Normal"
            if result.Mythic and result.Shiny then variantName = "Shiny Mythic"
            elseif result.Mythic then variantName = "Mythic"
            elseif result.Shiny  then variantName = "Shiny" end
            local gotName = (result.Name or "Unknown").." ("..variantName..")"
            setAction("Rebirth: got "..gotName.."!")
            log("REBIRTH","Result: "..gotName)
            State.rebirthLastCount = 0
        elseif ok and result == nil then
            setAction("Rebirth: server returned nil (cooldown?)")
            log("REBIRTH","Server returned nil — likely on cooldown")
            task.wait(10)
        else
            setAction("Rebirth: error — "..tostring(result))
            log("REBIRTH","Error: "..tostring(result))
            task.wait(5)
        end

        task.wait(3)
    end
    setAction("Idle")
    log("REBIRTH","stopped")
end

