-- GI HELPERS
-- ══════════════════════════════════════════
local function getGINeeds()
    local data = LocalData:Get()
    if not data then return true,false,false,false,{} end
    local prog = {}
    local needR,needL,needB = false,false,false
    local allDone = true
    for i, quest in ipairs(GlobalIncentiveUtil.Quests) do
        local active = QuestUtil:FindById(data, quest.Id)
        local t1 = quest.Tasks[1]
        local req = t1.Amount
        local p, done = 0, false
        if active then
            if active.Claimed then done=true p=req
            else p=active.Progress and active.Progress[1] or 0 done=(p>=req) end
        else done=true p=req end
        prog[i] = {pct=math.min(100,math.floor((p/math.max(req,1))*100)), done=done, prog=p, req=req}
        if not done then
            allDone = false
            if t1.Type=="Hatch" then if req>=500 then needR=true else needL=true end
            elseif t1.Type=="Bubbles" then needB=true end
        end
    end
    return allDone,needR,needL,needB,prog
end
local function doClaimGIRewards()
    local data = LocalData:Get()
    if not data or not data.GlobalIncentive then return end
    local gi = data.GlobalIncentive
    for i, quest in ipairs(GlobalIncentiveUtil.Quests) do
        local active = QuestUtil:FindById(data, quest.Id)
        if ((active==nil) or active.Claimed) and (not gi.ClaimedRewards or not gi.ClaimedRewards[tostring(i)]) then
            pcall(function() Remote:FireServer("ClaimGlobalIncentiveTrack", i) end) task.wait(0.4)
        end
    end
    if not gi.ClaimedGift then
        pcall(function() Remote:FireServer("ClaimGlobalIncentiveQuest") end) task.wait(0.4)
    end
    local gs = workspace:GetAttribute("GlobalIncentive") or 0
    if gi.ClaimedIncentives and GlobalIncentiveUtil.IncentiveRewards then
        for i, reward in ipairs(GlobalIncentiveUtil.IncentiveRewards) do
            if gs>=reward.Requirement and not gi.ClaimedIncentives[tostring(i)] then
                pcall(function() Remote:FireServer("ClaimGlobalIncentive", i) end) task.wait(0.4)
            end
        end
    end
end

-- ══════════════════════════════════════════
-- GI LOOP — DO NOT MODIFY TP/GUARD LOGIC
-- ══════════════════════════════════════════
local function runGILoop()
    log("GI","started | selectedEggKey="..tostring(State.selectedEggKey))
    while State.giRunning do
        local allDone,needR,needL,needB = getGINeeds()
        if allDone then
            if not State.giQuestsDone then
                State.giQuestsDone = true
                clearAnchor()
                setAction("G.Inc done — idle")
                log("GI","quests done — idle")
                if State.claimGIOn then doClaimGIRewards() end
            end
            local data = LocalData:Get()
            local cur  = data and data.GlobalIncentive and data.GlobalIncentive.QuestSeed or 0
            if State.giOldSeed == nil then State.giOldSeed = cur end
            if cur ~= State.giOldSeed then
                log("GI","new seed — resetting")
                State.giOldSeed    = nil
                State.giMode       = "idle"
                State.giQuestsDone = false
                clearAnchor()
                setAction("G.Inc: new seed")
            else
                setAction("G.Inc done — idle")
                task.wait(2)
            end
        else
            State.giQuestsDone = false
            State.giOldSeed    = nil
            local function giActive() return State.giRunning and not State.giQuestsDone end
            if needB then
                local bp = EGG_POSITIONS.BubbleZone
                if bp then
                    if State.giMode ~= "bub" then State.giMode="bub" clearAnchor() setAction("G.Inc: bubble") end
                    ensureAt("gi_bubble", bp, giActive)
                    pcall(function() Remote:FireServer("BlowBubble") end) task.wait(0.1)
                else setAction("G.Inc: save Bubble Zone!") task.wait(2) end
            elseif needL then
                local sp = EGG_POSITIONS.SpikeyEgg
                if sp then
                    if State.giMode ~= "leg" then State.giMode="leg" clearAnchor() setAction("G.Inc: Spikey") end
                    ensureAt("gi_spikey", sp, giActive) spamER()
                else setAction("G.Inc: no Spikey pos!") task.wait(2) end
            elseif needR then
                local rp = EGG_POSITIONS[State.selectedEggKey]
                if rp then
                    if State.giMode ~= "reg" then State.giMode="reg" clearAnchor() setAction("G.Inc: "..State.selectedEggName) end
                    ensureAt("gi_reg_"..State.selectedEggKey, rp, giActive) spamER()
                else setAction("G.Inc: save egg pos!") task.wait(2) end
            else task.wait(1) end
        end
        task.wait(0.05)
    end
    State.giMode = "idle"
    clearAnchor()
    setAction("Idle")
    log("GI","stopped")
end

-- ══════════════════════════════════════════
-- GEM GENIE HELPERS
-- ══════════════════════════════════════════
local function genieSecsUntilReady()
    local data = LocalData:Get()
    if not data or not data.GemGenie then return 0 end
    local nextTime = data.GemGenie.Next or 0
    return math.max(0, nextTime - DateTime.now().UnixTimestamp)
end
local function getActiveGenieQuest()
    local data = LocalData:Get()
    if not data then return nil end
    return QuestUtil:FindById(data, "gem-genie")
end
local function getGenieSlotDef(data, slot)
    if not GenieQuest or not data or not data.GemGenie then return nil end
    local seed = data.GemGenie.Seed
    local ok, def = pcall(function() return GenieQuest(data, seed + (slot - 1)) end)
    return ok and def or nil
end
local function isGenieQuestDone(quest)
    if not quest then return false end
    if quest.Claimed then return true end
    if not quest.Tasks or not quest.Progress then return false end
    for i, t1 in ipairs(quest.Tasks) do
        if not isBlacklistedTask(t1) then
            local prog = quest.Progress[i] or 0
            local req  = getTaskReq(t1)
            if req > 0 and prog < req then return false end
        end
    end
    return true
end
local function pickBestGenieSlot(data)
    for slot = 1, 3 do
        local def = getGenieSlotDef(data, slot)
        if def and not slotHasBlacklistedTask(def.Tasks) then
            log("GENIE","Best slot: "..slot)
            return slot
        end
    end
    log("GENIE","All slots blacklisted — falling back to slot 1")
    return 1
end
local function findGenieSlotWithReward(data, targetName)
    if not GenieQuest or not data or not data.GemGenie then return nil end
    local target = targetName:lower()
    for slot = 1, 3 do
        local def = getGenieSlotDef(data, slot)
        if def then
            if slotHasBlacklistedTask(def.Tasks) then
                log("GENIE","Slot "..slot.." skipped (blacklisted tasks)")
            elseif def.Rewards then
                for _, reward in ipairs(def.Rewards) do
                    local rname = (reward.Name or ""):lower()
                    if rname:find(target, 1, true) then
                        log("GENIE","Slot "..slot.." has reward matching '"..targetName.."'")
                        return slot
                    end
                end
            end
        end
    end
    return nil
end

-- ══════════════════════════════════════════
-- GEM GENIE TASK EXECUTOR
-- ══════════════════════════════════════════
local function executeGenieTask(t1, taskIdx, sc)
    local req = getTaskReq(t1)
    local function progDone()
        local fresh = getActiveGenieQuest()
        if not fresh then return true end
        if fresh.Claimed then return true end
        if isBlacklistedTask(t1) then return true end
        local p = fresh.Progress and fresh.Progress[taskIdx] or 0
        return req > 0 and p >= req
    end
    if progDone() then log("GENIE","Task "..taskIdx.." already done") return end
    local act, extra = resolveQuestAction(t1)
    log("GENIE","Task "..taskIdx.." act="..act.." extra="..tostring(extra).." req="..req)
    local function sf(t) setAction("Genie: "..t) end
    if act == "_skip" then
        log("GENIE","Task "..taskIdx.." blacklisted (_skip)") return
    elseif act == "_gem" then
        doCurrencyCollect("Gems", progDone, sc, sf)
    elseif act == "_coin" then
        local cur = t1.Item and t1.Item.Currency or "Coins"
        doCurrencyCollect(cur, progDone, sc, sf)
    elseif act == "_bubble" then
        doBubble(progDone, sc, sf)
    elseif act == "_hatch_specific" then
        local useKey = resolveHatchKey(extra, nil)
        doHatchAtKey(useKey, progDone, sc, sf)
    elseif act == "_hatch_rarity" then
        local useKey = resolveHatchKey(nil, extra)
        doHatchAtKey(useKey, progDone, sc, sf)
    else
        local useKey = resolveHatchKey(nil, nil)
        doHatchAtKey(useKey, progDone, sc, sf)
    end
end

-- ══════════════════════════════════════════
-- GEM GENIE LOOP
-- ══════════════════════════════════════════
local function runGenieLoop()
    log("GENIE","started mode="..tostring(State.genieMode).." target="..tostring(State.genieRerollTarget))
    while State.genieRunning do
        if giBlocking()           then setAction("Genie: waiting G.Inc")   task.wait(0.5) continue end
        if seasonBlocking()       then setAction("Genie: waiting Season")  task.wait(0.5) continue end
        if obsidianRiftBlocking() then setAction("Genie: waiting ObsRift") task.wait(0.5) continue end
        local data = LocalData:Get()
        if not data then task.wait(1) continue end
        local secsLeft = genieSecsUntilReady()
        if secsLeft > 0 then
            setAction("Genie: ready in " .. formatTime(secsLeft))
            State.genieQuestActive = false
            State.genieQuestDone   = false
            task.wait(5)
            continue
        end
        local function sc()
            return State.genieRunning
                and not giBlocking()
                and not seasonBlocking()
                and not obsidianRiftBlocking()
        end
        local activeQuest = getActiveGenieQuest()
        if activeQuest and not isGenieQuestDone(activeQuest) then
            log("GENIE","Resuming active quest")
            State.genieQuestActive = true
            State.genieQuestDone   = false
            if activeQuest.Tasks then
                for i, t1 in ipairs(activeQuest.Tasks) do
                    if not sc() then break end
                    executeGenieTask(t1, i, sc)
                end
            end
            State.genieQuestActive = false
            State.genieQuestDone   = true
            setAction("Genie: quest done — waiting cooldown")
        elseif activeQuest and isGenieQuestDone(activeQuest) then
            State.genieQuestActive = false
            State.genieQuestDone   = true
            setAction("Genie: quest done — waiting cooldown")
            task.wait(5)
        else
            State.genieQuestActive = false
            State.genieQuestDone   = false
            local slotToPick = 1
            if State.genieMode == "reroll" and State.genieRerollTarget and State.genieRerollTarget ~= "" then
                local maxRerolls = 30
                local rolls      = 0
                while State.genieRunning and rolls <= maxRerolls do
                    if giBlocking() or seasonBlocking() or obsidianRiftBlocking() then break end
                    local freshData = LocalData:Get()
                    if not freshData then break end
                    local foundSlot = findGenieSlotWithReward(freshData, State.genieRerollTarget)
                    if foundSlot then
                        slotToPick = foundSlot
                        log("GENIE","Found '"..State.genieRerollTarget.."' in slot "..foundSlot.." after "..rolls.." rerolls")
                        break
                    end
                    if rolls >= maxRerolls then
                        slotToPick = pickBestGenieSlot(freshData)
                        break
                    end
                    setAction("Genie: rerolling ("..rolls.."/"..maxRerolls..") for "..State.genieRerollTarget)
                    pcall(function() Remote:FireServer("RerollGenie") end)
                    rolls += 1
                    task.wait(1)
                end
            else
                local freshData = LocalData:Get()
                if freshData then slotToPick = pickBestGenieSlot(freshData) end
            end
            if not State.genieRunning then break end
            setAction("Genie: picking slot "..slotToPick)
            pcall(function() Remote:FireServer("StartGenieQuest", slotToPick) end)
            local deadline = tick() + 5
            local newQuest = nil
            repeat task.wait(0.3) newQuest = getActiveGenieQuest()
            until newQuest or tick() >= deadline
            if not newQuest then
                log("GENIE","Quest not found after picking slot — retrying")
                task.wait(2) continue
            end
            State.genieQuestActive = true
            State.genieQuestDone   = false
            if newQuest.Tasks then
                for i, t1 in ipairs(newQuest.Tasks) do
                    if not sc() then break end
                    executeGenieTask(t1, i, sc)
                end
            end
            State.genieQuestActive = false
            State.genieQuestDone   = true
            setAction("Genie: quest done — waiting cooldown")
        end
        task.wait(1)
    end
    State.genieQuestActive = false
    State.genieQuestDone   = false
    clearAnchor()
    setAction("Idle")
    log("GENIE","stopped")
end

-- ══════════════════════════════════════════
-- HATCH LOOP — DO NOT MODIFY TP/GUARD LOGIC
-- ══════════════════════════════════════════
local function runHatchLoop()
    log("HATCH","started egg="..tostring(State.selectedEggKey))
    while State.hatchRunning do
        if giBlocking()           then setAction("Hatch: waiting G.Inc")   task.wait(0.5) continue end
        if seasonBlocking()       then setAction("Hatch: waiting Season")  task.wait(0.5) continue end
        if genieBlocking()        then setAction("Hatch: waiting Genie")   task.wait(0.5) continue end
