end
local function resolveEggKey(raw)
    if not raw or raw=="" then return nil end
    if EGG_KEY_TO_NAME[raw] then return raw end
    if EGG_NAME_TO_KEY[raw] then return EGG_NAME_TO_KEY[raw] end
    local s = raw:gsub("%s+","")
    if EGG_KEY_TO_NAME[s] then return s end
    if EGG_KEY_TO_NAME[s.."Egg"] then return s.."Egg" end
    return s
end

