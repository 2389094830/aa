                task.wait(0.25)
            end
            if State.obsidianRiftSpawnHeight then
                local spawnHeight = State.obsidianRiftSpawnHeight
                local deadline2 = tick() + 8
                local positions = {}
                repeat
                    positions = getObsidianRiftPlatformPositions()
                    if #positions == 0 then task.wait(0.25) end
                until #positions > 0 or tick() >= deadline2
                if #positions > 0 then
                    hatchPos = pickClosestPlatform(positions, spawnHeight)
