                        tp(hatchPos, "obsrift_reanchor")
                    end
                else break end
                lastReTp = tick()
            end
            spamER() task.wait(0.05)
        end
        clearAnchor()
        State.obsidianRiftHatchPos    = nil
        State.obsidianRiftSpawnHeight = nil
        if State.obsidianRiftRunning and not giBlocking() and not seasonBlocking() then
            setAction("ObsRift: cooldown 3s") task.wait(3)
        end
    end
    clearAnchor() setAction("Idle") log("OBSRIFT","stopped")
end

