                    local groundPos = EGG_POSITIONS[eggKey] or EGG_POSITIONS.SpikeyEgg
                    hatchPos = Vector3.new(groundPos.X, spawnHeight + 2, groundPos.Z)
                end
            else
                hatchPos = findExistingObsidianRiftPos(5)
                if not hatchPos then setAction("ObsRift: no platform found") task.wait(5) continue end
            end
