        local track = Instance.new("Frame", f)
        track.Size             = UDim2.fromOffset(34, 16)
        track.Position         = UDim2.new(1, -40, 0.5, -8)
        track.BackgroundColor3 = defaultOn and ac or P.line
        track.BorderSizePixel  = 0
        Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
        local knob = Instance.new("Frame", track)
        knob.Size             = UDim2.fromOffset(10, 10)
        knob.Position         = defaultOn and UDim2.fromOffset(21, 3) or UDim2.fromOffset(3, 3)
        knob.BackgroundColor3 = defaultOn and P.bg or P.muted
        knob.BorderSizePixel  = 0
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
        local state = defaultOn
        local cb    = nil
        local function setState(val)
            state                  = val
            track.BackgroundColor3 = val and ac or P.line
            knob.Position          = val and UDim2.fromOffset(21, 3) or UDim2.fromOffset(3, 3)
            knob.BackgroundColor3  = val and P.bg or P.muted
            stroke.Color           = val and ac or P.line
            nameLbl.TextColor3     = val and P.txt or P.muted
            if cb then cb(val) end
        end
        local hit = Instance.new("TextButton", f)
        hit.Size                   = UDim2.fromScale(1, 1)
        hit.BackgroundTransparency = 1
        hit.Text                   = ""
        hit.ZIndex                 = 13
        hit.MouseButton1Click:Connect(function() setState(not state) end)
        return f,
            function() return state end,
            function(fn) cb = fn end,
            function(val) setState(val) end
    end

