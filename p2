local activeTab = "console"
local function setTab(key)
    activeTab = key
    for _, tab in ipairs(TABS) do
        local k = tab.key
        pages[k].scroll.Visible = (k == key)
        local b = tabBtns[k]
        if k == key then
            b.BackgroundColor3       = tab.col
            b.BackgroundTransparency = 0.65
            b.TextColor3             = tab.col
        else
            b.BackgroundColor3       = P.offbg
            b.BackgroundTransparency = 0.3
            b.TextColor3             = P.muted
        end
    end
end
for _, tab in ipairs(TABS) do
    local key = tab.key
    tabBtns[key].MouseButton1Click:Connect(function() setTab(key) end)
end

