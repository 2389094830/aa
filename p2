local function buildQuests()
    local Q = makeWidgets(pages["quests"].content)
    Q.section("Season", P.sky)
    local _, _, setSeasonCb = Q.toggle("Auto Season Quests", State.seasonRunning, P.sky)
    Q.gap(5)
    Q.section("Hourly", P.sky)
    local hourlyRows = {}
    for i = 1, 3 do local _, nl, sl = Q.questRow("Loading...") hourlyRows[i] = {n=nl, s=sl} end
    local hourlyRstLbl = Q.note("Resets: ...")
    Q.gap(5)
    Q.section("Daily", P.sky)
    local dailyRows = {}
    for i = 1, 3 do local _, nl, sl = Q.questRow("Loading...") dailyRows[i] = {n=nl, s=sl} end
    local dailyRstLbl = Q.note("Resets: ...")
    Q.gap(5)
    Q.section("Summary", P.muted)
    local questSumLbl = Q.pill("...")
    local questPtsLbl = Q.note("Points: ...")

    setSeasonCb(function(on)
        if on then FH.startSeason() else FH.stopSeason() end
    end)

    local function getTaskReqLocal(t1)
        if not t1 then return 0 end
        if t1.Type == "Collect" then return (t1.Item and t1.Item.Amount) or t1.Amount or 0 end
        return t1.Amount or 0
    end

    local function getQE(data, ctype, idx)
        local id = ("%s-challenge-%d"):format(string.lower(ctype), idx)
        local ok, QU = pcall(require, game:GetService("ReplicatedStorage").Shared.Utils.Stats.QuestUtil)
        if ok and QU.FindById then return QU:FindById(data, id) end
        if data and data.Quests then
            for _, q in pairs(data.Quests) do
                if type(q)=="table" and q.Id==id then return q end
            end
        end
    end

    local function fillRows(ctype, rows, rstLbl)
        local ok, LD = pcall(require, game:GetService("ReplicatedStorage").Client.Framework.Services.LocalData)
        if not ok then return end
        local data = LD:Get() if not data then return end
        local secsH   = 3600  - (DateTime.now().UnixTimestamp % 3600)
        local secsMid  = 86400 - (DateTime.now().UnixTimestamp % 86400)
        for i = 1, 3 do
            local quest = getQE(data, ctype, i)
            local row   = rows[i]
            if quest then
                local prog = (quest.Progress and quest.Progress[1]) or 0
                local t1   = quest.Tasks and quest.Tasks[1]
                local req  = getTaskReqLocal(t1)
                local done = quest.Claimed or (req > 0 and prog >= req)
                local ok2, QU2 = pcall(require, game:GetService("ReplicatedStorage").Shared.Utils.Stats.QuestUtil)
                local tstr = t1 and ((ok2 and QU2.FormatTask and QU2:FormatTask(t1)) or (t1.Type or "?").." x"..req) or "Quest #"..i
                row.n.Text = tstr
                if done then
                    row.n.TextColor3 = P.lime row.s.Text = "[v]" row.s.TextColor3 = P.lime
                else
                    row.n.TextColor3 = P.muted row.s.Text = prog.."/"..req row.s.TextColor3 = P.amber
                end
            else
                row.n.Text = "-" row.n.TextColor3 = P.dim row.s.Text = ""
            end
        end
        rstLbl.Text = "Resets " .. FH.formatTime(ctype == "Hourly" and secsH or secsMid)
    end

    local function refreshUI()
        local ok, LD = pcall(require, game:GetService("ReplicatedStorage").Client.Framework.Services.LocalData)
        if not ok then return end
        local data = LD:Get() if not data then return end
        fillRows("Hourly", hourlyRows, hourlyRstLbl)
        fillRows("Daily",  dailyRows,  dailyRstLbl)
        if data.Season then
            questPtsLbl.Text = "Points: "..tostring(data.Season.Points or 0).."  Lv "..tostring(data.Season.Level or 0)
        end
        if State.hourlyDone and State.dailyDone then
            questSumLbl.Text = "All done!" questSumLbl.TextColor3 = P.lime
        elseif State.hourlyDone then
            questSumLbl.Text = "Hourly done" questSumLbl.TextColor3 = P.amber
        elseif State.dailyDone then
            questSumLbl.Text = "Daily done" questSumLbl.TextColor3 = P.amber
        else
            questSumLbl.Text = "In progress" questSumLbl.TextColor3 = P.muted
        end
    end
    task.spawn(function() while task.wait(5) do refreshUI() end end)
end
