local function buildRebirth()
    local RB = makeWidgets(pages["rebirth"].content)

    RB.section("Rebirth Machine", P.rebirth)
    RB.note("Converts 5x matching Secret pets into a random Secret.", P.muted)
    RB.note("Skips locked, XL, and team-equipped pets.", P.dim)
    RB.gap(5)

    RB.section("Pet Name", P.rebirth)
    local _, petNameBox = RB.strInput("Pet Name", State.rebirthConfig.petName or "Hyperwave Doggy")
    RB.gap(3)
    local applyPetBtn = RB.actionBtn("[>] Apply Pet Name", P.rebirth)
    RB.gap(5)

    RB.section("Status", P.rebirth)
    local rebirthStatusLbl = RB.pill("Off")
    RB.gap(3)
    local rebirthCountLbl  = RB.note("Found: checking...", P.muted)
    RB.gap(3)
    local rebirthLastLbl   = RB.note("Last result: —", P.dim)
    RB.gap(5)

    RB.section("Control", P.lime)
    local _, getRebirthState, setRebirthCb, forceRebirthToggle = RB.toggle("Auto Rebirth Machine", State.rebirthRunning, P.lime)
    RB.gap(3)
    RB.note("Will only fire when exactly 5+ matching pets are available.", P.dim)
    RB.gap(5)

    RB.section("Manual", P.rebirth)
    local fireOnceBtn = RB.actionBtn("[>] Fire Once Now", P.rebirth)

    applyPetBtn.MouseButton1Click:Connect(function()
        local name = petNameBox.Text:match("^%s*(.-)%s*$")
        if name and name ~= "" then
            State.rebirthConfig.petName = name
            applyPetBtn.Text = "[v] Applied!"
            task.delay(2, function() applyPetBtn.Text = "[>] Apply Pet Name" end)
        end
    end)

    setRebirthCb(function(on)
        if on then
            FH.startRebirthMachine()
            rebirthStatusLbl.Text       = "Running"
            rebirthStatusLbl.TextColor3 = P.rebirth
        else
            FH.stopRebirthMachine()
            rebirthStatusLbl.Text       = "Off"
            rebirthStatusLbl.TextColor3 = P.muted
        end
    end)

    fireOnceBtn.MouseButton1Click:Connect(function()
        local petName = State.rebirthConfig.petName
        local pets    = FH.getRebirthPets(petName)
        if not pets then
            fireOnceBtn.Text = "Not enough pets!"
            task.delay(2, function() fireOnceBtn.Text = "[>] Fire Once Now" end)
            return
        end
        local ids = {}
        for _, p in ipairs(pets) do table.insert(ids, p.Id) end
        fireOnceBtn.Text = "Converting..."
        task.spawn(function()
            local ok, LD = pcall(require, game:GetService("ReplicatedStorage").Client.Framework.Services.LocalData)
            if not ok then fireOnceBtn.Text = "Error" task.delay(2, function() fireOnceBtn.Text = "[>] Fire Once Now" end) return end
            local Remote2 = nil
            pcall(function() Remote2 = require(game:GetService("ReplicatedStorage").Shared.Framework.Network.Remote) end)
            if not Remote2 then fireOnceBtn.Text = "No Remote" task.delay(2, function() fireOnceBtn.Text = "[>] Fire Once Now" end) return end
            local ok2, result = pcall(function() return Remote2:InvokeServer("UseRebirthMachine", ids) end)
            if ok2 and result then
                local variantName = result.Mythic and result.Shiny and "Shiny Mythic" or result.Mythic and "Mythic" or result.Shiny and "Shiny" or "Normal"
                local gotName = (result.Name or "?").." ("..variantName..")"
                rebirthLastLbl.Text       = "Last result: "..gotName
                rebirthLastLbl.TextColor3 = P.lime
                fireOnceBtn.Text = "[v] Got "..gotName.."!"
            else
                rebirthLastLbl.Text       = "Last result: nil/error"
                rebirthLastLbl.TextColor3 = P.rose
                fireOnceBtn.Text = "Failed/cooldown"
            end
            task.delay(3, function() fireOnceBtn.Text = "[>] Fire Once Now" end)
        end)
    end)

    -- Sync toggle + status
    task.spawn(function()
        while task.wait(1) do
            if getRebirthState() ~= State.rebirthRunning then forceRebirthToggle(State.rebirthRunning) end
            if State.rebirthRunning then
                rebirthStatusLbl.Text       = State.action
                rebirthStatusLbl.TextColor3 = P.rebirth
            end
            -- Count matching pets
            local count = 0
            local ok, LD = pcall(require, game:GetService("ReplicatedStorage").Client.Framework.Services.LocalData)
            if ok then
                local data = LD:Get()
                if data and data.Pets then
                    local petName = State.rebirthConfig.petName
                    for _, p in ipairs(data.Pets) do
                        if p.Name == petName then count += 1 end
                    end
                end
            end
            local petName = State.rebirthConfig.petName
            local eligible = FH.getRebirthPets and FH.getRebirthPets(petName)
            local eligCount = eligible and #eligible or 0
            rebirthCountLbl.Text       = "Found: "..count.." total, "..eligCount.." eligible (need 5)"
            rebirthCountLbl.TextColor3 = eligCount >= 5 and P.lime or P.amber
        end
    end)
end
buildRebirth()

