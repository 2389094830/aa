        State.webhookUrl         = url
        webhookStatus.Text       = "Status: sending test..."
        webhookStatus.TextColor3 = P.amber
        task.spawn(function()
            local ok, err = FH.sendWebhookEmbed("Test Pet", "Shiny ", true)
            if ok then
                webhookStatus.Text="Status: test sent!" webhookStatus.TextColor3=P.lime
                task.delay(4, function()
                    webhookStatus.Text       = State.webhookEnabled and "Status: listening..." or "Status: disabled"
                    webhookStatus.TextColor3 = State.webhookEnabled and P.lime or P.dim
                end)
            else
                webhookStatus.Text="Status: failed — "..tostring(err or "?"):sub(1,28)
                webhookStatus.TextColor3=P.rose
            end
        end)
    end)
    task.spawn(function()
        while task.wait(1) do prCountLbl.Text = "Collected: " .. State.prCount end
    end)
end
