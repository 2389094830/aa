            item.MouseLeave:Connect(function() item.BackgroundColor3 = P.panel end)
            item.MouseButton1Click:Connect(function()
                currentName = name
                dBtn.Text   = "[v]  " .. name
                if onSelect then onSelect(name, FH.EGG_NAME_TO_KEY[name]) end
                closeDD()
            end)
        end

        dBtn.MouseButton1Click:Connect(function()
            isOpen        = not isOpen
            panel.Visible = isOpen
            dBtn.Text     = (isOpen and "[^]  " or "[v]  ") .. (currentName or State.selectedEggName)
            if isOpen then
                local a = dBtn.AbsolutePosition
                panel.Position = UDim2.fromOffset(a.X, a.Y + 28)
                if posConn then posConn:Disconnect() end
                posConn = RunService.RenderStepped:Connect(function()
                    if not isOpen then posConn:Disconnect() posConn = nil return end
                    local ab = dBtn.AbsolutePosition
                    panel.Position = UDim2.fromOffset(ab.X, ab.Y + 28)
                end)
            end
        end)

        return holder, dBtn, function(fn) onSelect = fn end
    end

    return w
end

